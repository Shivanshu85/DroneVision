# DroneVision Environment Variables Template
# Copy this file to .env and configure as needed

# Device configuration (e.g. 0 to use first GPU, or empty for CPU/auto selection)
CUDA_VISIBLE_DEVICES=0

# MLflow Tracking settings
MLFLOW_TRACKING_URI=./mlruns
MLFLOW_EXPERIMENT_NAME=DroneVision-Detection

# Gradio Demo server configuration
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=False

# Package configurations
PYTHONPATH=.
